---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
<channel>
  <title>{{ site.brandName }} — Guides</title>
  <link>{{ site.url }}{{ "/guides/" | url }}</link>
  <atom:link href="{{ site.url }}{{ "/feed.xml" | url }}" rel="self" type="application/rss+xml"/>
  <description>Practical guides on Japanese visas, immigration, and nationality.</description>
  <language>en</language>
  {%- for g in collections.guidesEn | limit(20) %}
  <item>
    <title>{{ g.data.title }}</title>
    <link>{{ site.url }}{{ g.url | url }}</link>
    <guid>{{ site.url }}{{ g.url | url }}</guid>
    <pubDate>{{ g.date.toUTCString() }}</pubDate>
    <description>{{ g.data.description }}</description>
  </item>
  {%- endfor %}
</channel>
</rss>
